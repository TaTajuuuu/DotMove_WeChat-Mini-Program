.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  background: #f5f7f3;
}

/* 自定义导航栏 */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  margin-top: 20rpx;
}

.nav-back {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.back-arrow {
  font-size: 36rpx;
  color: #20251f;
}

.nav-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
}

.nav-capsule {
  width: 60rpx;
  height: 60rpx;
}

/* Hero 区域 */
.hero-section {
  margin-top: 40rpx;
  padding: 40rpx 36rpx;
  background: linear-gradient(135deg, #20251f 0%, #3a4a35 100%);
  border-radius: 16rpx;
  color: #ffffff;
}

.hero-title {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #ffffff;
  margin-bottom: 16rpx;
}

.hero-desc {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 24rpx;
}

.hero-badge {
  display: inline-block;
  padding: 8rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #ffffff;
}

/* 卡片通用样式 */
.info-card,
.target-card {
  margin-top: 28rpx;
  padding: 32rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 12rpx;
  background: rgba(255, 255, 255, 0.94);
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 28rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
}

/* 标签样式 */
.tag {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag-member {
  background: #e8f5e9;
  color: #2e7d32;
}

.tag-completed {
  background: #e8f5e9;
  color: #2e7d32;
}

/* 成员信息样式 */
.info-row {
  display: flex;
  gap: 24rpx;
  margin-bottom: 20rpx;
}

.info-field {
  flex: 1;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #687064;
  margin-bottom: 8rpx;
}

.field-value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #20251f;
}

.coin-value {
  color: #f57c00;
  font-size: 36rpx;
  font-weight: 800;
}

.info-desc {
  display: block;
  font-size: 24rpx;
  color: #687064;
  margin-top: 16rpx;
  line-height: 1.5;
}

.coin-row {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #dfe5d8;
}

/* 目标完成情况样式 */
.target-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f4ed;
}

.target-row:last-child {
  border-bottom: none;
}

.target-left {
  flex: 1;
}

.target-name {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #20251f;
  margin-bottom: 8rpx;
}

.target-value {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
}

.target-right {
  flex-shrink: 0;
  text-align: right;
}

.target-date,
.target-note {
  display: block;
  font-size: 22rpx;
  color: #687064;
  margin-top: 4rpx;
}
