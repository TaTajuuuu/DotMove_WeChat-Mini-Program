.goal-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-top: 28rpx;
}

.goal-card,
.coin-card {
  padding: 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .94);
}

.goal-card.selected {
  border-color: #2f7d4f;
  background: #f0f4e8;
}

.goal-name,
.goal-desc,
.field-label,
.hint,
.error-text {
  display: block;
}

.goal-name,
.field-label {
  color: #20251f;
  font-size: 28rpx;
  font-weight: 800;
}

.goal-desc,
.hint {
  margin-top: 8rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.45;
}

.coin-card {
  margin-top: 24rpx;
}

.coin-input {
  height: 84rpx;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: #fff;
  font-size: 30rpx;
}

.error-text {
  margin-top: 18rpx;
  color: #ba5148;
  font-size: 26rpx;
}

.primary-btn {
  width: 100%;
  height: 84rpx;
  margin-top: 28rpx;
  border-radius: 8rpx;
  color: #fff;
  background: #2f7d4f;
  font-size: 28rpx;
  font-weight: 800;
}
