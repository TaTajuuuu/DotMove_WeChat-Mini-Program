/* ============================================
   目标类型设置页 - 严格按原型图还原
   prototype-04-target-type-settings.html
   ============================================ */

.target-page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ===== 导航栏 ===== */
.nav {
  display: grid;
  grid-template-columns: 68rpx 1fr 144rpx;
  align-items: center;
  height: 96rpx;
  padding: 0 0 0 8rpx;
}

.back {
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, .72);
  position: relative;
}

.back::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}

.capsule {
  justify-self: end;
  display: flex;
  width: 144rpx;
  height: 64rpx;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(32, 37, 31, .16);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, .76);
}

.circle-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #20251f;
  border-radius: 50%;
}

.more-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}

/* ===== Hero 区域 ===== */
.hero {
  padding: 28rpx 0 20rpx;
}

.hero-title {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}

.hero-text {
  flex: 1;
}

.hero-heading {
  display: block;
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: bold;
  color: #20251f;
  letter-spacing: 0;
  white-space: pre-line;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  color: #687064;
  font-size: 26rpx;
  line-height: 1.55;
}

.badge {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
  border: 1rpx solid rgba(47, 125, 79, .2);
  color: #23613e;
  background: rgba(255, 255, 255, .72);
}

.badge.locked {
  color: #8a9384;
  border-color: rgba(138, 147, 132, .2);
  background: rgba(229, 233, 223, .76);
}

/* ===== 卡片 & 面板 ===== */
.card {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}

.panel {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #20251f;
}

.section-meta {
  color: #8a9384;
  font-size: 24rpx;
}

/* ===== 目标类型网格 ===== */
.goal-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.goal-type {
  min-height: 140rpx;
  padding: 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
  display: flex;
  flex-direction: column;
  justify-content: center;
  transition: background .2s ease, border-color .2s ease, color .2s ease;
}

.goal-type.selected {
  color: #fff;
  border-color: #2f7d4f;
  background: #2f7d4f;
}

.goal-name {
  display: block;
  font-size: 28rpx;
  font-weight: bold;
  line-height: 1.25;
  color: inherit;
}

.goal-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  line-height: 1.35;
  opacity: .74;
  color: inherit;
}

/* ===== 一点币 ===== */
.coin-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  min-height: 100rpx;
  padding: 0 26rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
}

.coin-input {
  flex: 1;
  height: 100%;
  font-size: 32rpx;
  font-weight: 900;
  color: #23613e;
  background: transparent;
  border: none;
  padding: 0;
}

.coin-display {
  font-size: 32rpx;
  font-weight: 900;
  color: #23613e;
}

.coin-label {
  color: #8a9384;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* ===== 提示 ===== */
.notice {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(240, 180, 65, .28);
  border-radius: 16rpx;
  color: #6c4a06;
  font-size: 24rpx;
  line-height: 1.45;
  background: rgba(255, 246, 225, .9);
}

.notice.danger {
  border-color: rgba(186, 81, 72, .28);
  color: #ba5148;
  background: rgba(255, 240, 240, .9);
}

/* ===== 按钮 ===== */
.primary-btn {
  width: 100%;
  min-height: 100rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  color: #fff;
  background: #2f7d4f;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 20rpx 48rpx rgba(47, 125, 79, .22);
}
