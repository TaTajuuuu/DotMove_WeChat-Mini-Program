<view class="page target-page">
  <!-- 导航栏 -->
  <view class="nav">
    <view class="back" bindtap="handleBack"></view>
    <text class="nav-title">目标类型</text>
    <view class="capsule">
      <view class="more-icon"><text></text></view>
      <view class="circle-icon"></view>
    </view>
  </view>

  <!-- Hero 区域 -->
  <view class="hero">
    <view class="hero-title">
      <view class="hero-text">
        <text class="hero-heading">目标设置选择\n本月运动目标类型和一点币。</text>
        <text class="hero-desc">仅未开始小组可修改整组目标配置。</text>
      </view>
      <view class="badge">{{targetStatusLabel}}</view>
    </view>
  </view>

  <!-- 目标类型 卡片 -->
  <view class="card">
    <view class="section-head">
      <text class="section-title">目标类型</text>
      <text class="section-meta">可多选</text>
    </view>
    <view class="goal-grid">
      <view
        wx:for="{{goalTypes}}"
        wx:key="key"
        class="goal-type {{item.selected ? 'selected' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleToggleGoal"
      >
        <text class="goal-name">{{item.name}}</text>
        <text class="goal-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 一点币 面板 -->
  <view class="panel">
    <view class="section-head">
      <text class="section-title">一点币</text>
      <text class="section-meta">仅展示，不结算</text>
    </view>
    <view class="coin-row">
      <input
        class="coin-input"
        type="digit"
        value="{{coinValue}}"
        placeholder="0"
        bindinput="handleCoinInput"
      />
      <text class="coin-label">虚拟承诺值</text>
    </view>

    <!-- 错误提示 -->
    <view wx:if="{{errorMessage}}" class="notice danger">
      <text>{{errorMessage}}</text>
    </view>

    <!-- 下一步按钮 -->
    <button class="primary-btn" bindtap="handleNext">下一步：设置目标值</button>
  </view>

  <!-- 自定义底部导航 -->
  <custom-tab-bar />
</view>
