/* ===== 页面容器 ===== */
.values-page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ===== 导航栏 ===== */
.nav-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 96rpx;
}

.nav-back {
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 50%;
  background: rgba(255, 255, 255, .72);
  position: relative;
  flex-shrink: 0;
}
.nav-back::after {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #20251f;
  text-align: center;
}

.nav-placeholder {
  width: 68rpx;
  flex-shrink: 0;
}

/* ===== Hero 区域 ===== */
.hero {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
  margin-top: 16rpx;
  margin-bottom: 28rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: 800;
  color: #20251f;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  color: #687064;
  font-size: 26rpx;
  line-height: 1.55;
}

.status-badge {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border-radius: 999rpx;
  border: 1rpx solid rgba(47, 125, 79, .2);
  color: #23613e;
  background: rgba(255, 255, 255, .72);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
  white-space: nowrap;
}

/* ===== 卡片 ===== */
.card {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #20251f;
}

.section-meta {
  color: #8a9384;
  font-size: 24rpx;
  font-weight: 600;
}

/* ===== 字段列表 ===== */
.field-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.field {
  padding: 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 12rpx;
  background: #fbfcf8;
}

.field-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.sub-row {
  margin-top: 14rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 10rpx;
  background: #fff;
}

.field-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #20251f;
  white-space: nowrap;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  height: 64rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 10rpx;
  background: #fff;
  font-size: 30rpx;
  font-weight: 900;
  color: #23613e;
  text-align: right;
  min-width: 0;
}

.field-unit {
  flex-shrink: 0;
  margin-left: 10rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #8a9384;
}

.field-hint {
  display: block;
  margin-top: 12rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.4;
}

.sub-field {
  /* 子字段容器 */
}

.empty-hint {
  padding: 32rpx;
  text-align: center;
  color: #8a9384;
  font-size: 26rpx;
}

/* ===== 提示信息 ===== */
.notice {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(240, 180, 65, .28);
  border-radius: 12rpx;
  color: #6c4a06;
  background: rgba(255, 246, 225, .9);
  font-size: 24rpx;
  line-height: 1.5;
}

/* ===== 错误提示 ===== */
.error-text {
  display: block;
  margin-top: 24rpx;
  color: #ba5148;
  font-size: 26rpx;
  text-align: center;
}

/* ===== 主按钮 ===== */
.primary-btn {
  width: 100%;
  height: 92rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 12rpx;
  color: #fff;
  background: #2f7d4f;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 36rpx rgba(47, 125, 79, .22);
  line-height: 1.2;
}
.primary-btn[disabled] {
  opacity: .45;
  box-shadow: none;
}
