.field-card {
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .94);
}

.field-label,
.error-text {
  display: block;
}

.field-label {
  color: #20251f;
  font-size: 28rpx;
  font-weight: 800;
}

.field-label.sub {
  margin-top: 20rpx;
  color: #687064;
  font-size: 24rpx;
}

.number-input {
  height: 84rpx;
  margin-top: 14rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: #fff;
  font-size: 30rpx;
}

.error-text {
  margin-top: 18rpx;
  color: #ba5148;
  font-size: 26rpx;
}

.primary-btn {
  width: 100%;
  height: 84rpx;
  margin-top: 28rpx;
  border-radius: 8rpx;
  color: #fff;
  background: #2f7d4f;
  font-size: 28rpx;
  font-weight: 800;
}
