.form-card,
.preview-card,
.state-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .94);
}

.field-label,
.group-name,
.group-meta,
.counter,
.error-text {
  display: block;
}

.field-label,
.group-name {
  color: #20251f;
  font-size: 30rpx;
  font-weight: 800;
}

.invite-row {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.text-input {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: #fff;
  font-size: 28rpx;
}

.secondary-btn,
.primary-btn {
  height: 84rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.secondary-btn {
  width: 144rpx;
  color: #23613e;
  background: #f0f4e8;
}

.primary-btn {
  width: 100%;
  margin-top: 28rpx;
  color: #fff;
  background: #2f7d4f;
}

.group-meta,
.counter {
  margin-top: 10rpx;
  color: #687064;
  font-size: 24rpx;
}

.counter {
  text-align: right;
}

.notice {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 8rpx;
  color: #687064;
  background: #f0f4e8;
  font-size: 24rpx;
  line-height: 1.5;
}

.error-text {
  margin-top: 18rpx;
  color: #ba5148;
  font-size: 26rpx;
}
