.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 导航栏 */
.nav {
  display: grid;
  grid-template-columns: 68rpx 1fr 144rpx;
  align-items: center;
  height: 96rpx;
  padding: 0 0 0 8rpx;
}

.back {
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, .72);
  position: relative;
}

.back::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}

.capsule {
  justify-self: end;
  display: flex;
  width: 144rpx;
  height: 64rpx;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(32, 37, 31, .16);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, .76);
}

.circle-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #20251f;
  border-radius: 50%;
}

.more-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}

.more-icon::before,
.more-icon::after,
.more-icon span {
  content: "";
  position: absolute;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #20251f;
}

.more-icon::before { left: 2rpx; }
.more-icon span { left: 14rpx; }
.more-icon::after { left: 26rpx; }

/* Hero */
.hero {
  padding: 28rpx 0 24rpx;
}

.hero-title {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.hero-heading {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: 0;
  white-space: pre-line;
}

.hero-desc {
  margin-top: 16rpx;
  display: block;
  color: #687064;
  font-size: 26rpx;
  line-height: 1.55;
}

.month-badge {
  flex: 0 0 auto;
  padding: 14rpx 20rpx;
  border: 1rpx solid rgba(47, 125, 79, .2);
  border-radius: 999rpx;
  color: #23613e;
  background: rgba(255, 255, 255, .72);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

/* 卡片 */
.form-card,
.group-card {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}

.group-card + .form-card {
  margin-top: 24rpx;
}

.field-block + .field-block,
.form-card + .form-card {
  margin-top: 24rpx;
}

.label-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 18rpx;
}

.field-label {
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1.25;
}

.helper {
  color: #8a9384;
  font-size: 24rpx;
  line-height: 1.35;
}

/* 邀请码输入行 */
.invite-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.field-input {
  flex: 1;
  min-height: 88rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
  font-size: 30rpx;
  line-height: 1.5;
}

.preview-btn {
  flex-shrink: 0;
  min-height: 88rpx;
  padding: 0 32rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  color: #23613e;
  background: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

/* 小组预览卡片 */
.card-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.group-name {
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.22;
  letter-spacing: 0;
}

.group-subtitle {
  display: block;
  margin-top: 14rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.45;
}

.tag {
  flex: 0 0 auto;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.tag.active {
  color: #fff;
  background: #2f7d4f;
}

.tag.planned {
  color: #6c4a06;
  background: #fae6af;
}

/* 统计行 */
.stats {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 28rpx;
}

.stat {
  text-align: center;
}

.stat-value {
  display: block;
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
  line-height: 1.25;
}

.stat-label {
  display: block;
  margin-top: 6rpx;
  color: #687064;
  font-size: 22rpx;
  line-height: 1.35;
}

/* 隐私提示 */
.privacy {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #f7f9f3;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.55;
}

/* 输入框（带字数） */
.input-wrap {
  display: flex;
  align-items: center;
  min-height: 88rpx;
  padding: 0 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
}

.input-wrap .field-input {
  flex: 1;
  border: none;
  background: transparent;
  padding: 0;
  font-weight: 700;
}

.input-count {
  margin-left: auto;
  color: #8a9384;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

/* 错误提示 */
.notice {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(240, 180, 65, .28);
  border-radius: 16rpx;
  color: #6c4a06;
  background: rgba(255, 246, 225, .9);
  font-size: 24rpx;
  line-height: 1.45;
}

.notice.danger {
  border-color: rgba(186, 81, 72, .28);
  color: #ba5148;
  background: rgba(255, 235, 235, .9);
}

/* 按钮 */
.primary-btn {
  width: 100%;
  min-height: 96rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  color: #fff;
  background: #2f7d4f;
  font: inherit;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 20rpx 48rpx rgba(47, 125, 79, .22);
}

.primary-btn[disabled] {
  opacity: .55;
}

.secondary-btn {
  min-height: 80rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  color: #23613e;
  background: #fff;
  font: inherit;
  font-size: 28rpx;
  font-weight: 800;
}

/* 状态卡片 */
.state-card {
  margin-top: 48rpx;
  padding: 60rpx 28rpx;
  border: 1rpx dashed #dfe5d8;
  border-radius: 16rpx;
  text-align: center;
}

.state-text,
.error-text {
  display: block;
  color: #687064;
  font-size: 30rpx;
  line-height: 1.5;
}
