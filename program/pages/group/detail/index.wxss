.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 导航栏 */
.nav {
  display: grid;
  grid-template-columns: 68rpx 1fr 144rpx;
  align-items: center;
  height: 96rpx;
  padding: 0 0 0 8rpx;
}

.back {
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, .72);
  position: relative;
}

.back::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}

.capsule {
  justify-self: end;
  display: flex;
  width: 144rpx;
  height: 64rpx;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(32, 37, 31, .16);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, .76);
}

.circle-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #20251f;
  border-radius: 50%;
}

.more-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}

.more-icon::before,
.more-icon::after,
.more-icon span {
  content: "";
  position: absolute;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #20251f;
}

.more-icon::before { left: 2rpx; }
.more-icon span { left: 14rpx; }
.more-icon::after { left: 26rpx; }

/* Hero */
.hero {
  padding: 28rpx 0 24rpx;
}

.hero-title {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.hero-heading {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: 0;
}

.hero-desc {
  margin-top: 16rpx;
  display: block;
  color: #687064;
  font-size: 28rpx;
  line-height: 1.55;
}

.month-badge {
  flex: 0 0 auto;
  padding: 14rpx 24rpx;
  border: 1rpx solid rgba(47, 125, 79, .2);
  border-radius: 999rpx;
  color: #23613e;
  background: rgba(255, 255, 255, .72);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

/* 卡片 */
.card,
.panel {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}

.card + .panel {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
}

.section-meta {
  color: #8a9384;
  font-size: 24rpx;
}

/* 管理标签 */
.tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.tag.active {
  color: #fff;
  background: #2f7d4f;
}

.manage-tag {
  /* 可点击的管理标签 */
}

/* 信息网格 */
.info-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16rpx;
}

.info {
  text-align: center;
}

.info-value {
  display: block;
  font-size: 34rpx;
  font-weight: 800;
  color: #20251f;
  line-height: 1.25;
}

.info-label {
  display: block;
  margin-top: 8rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.35;
}

/* 提示 */
.notice {
  margin-top: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  background: #f7f9f3;
  color: #687064;
  font-size: 26rpx;
  line-height: 1.55;
}

/* 成员列表 */
.member-list {
  display: grid;
  gap: 20rpx;
}

.member {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid rgba(223, 229, 216, .5);
}

.member:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.avatar {
  flex-shrink: 0;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: #e8efe0;
  color: #23613e;
  font-size: 30rpx;
  font-weight: 800;
  display: grid;
  place-items: center;
}

.avatar.alt {
  background: #d4ead4;
}

.avatar.mute {
  opacity: .45;
}

.member-info {
  flex: 1;
  min-width: 0;
}

.member-name {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #20251f;
  line-height: 1.3;
}

.member-meta {
  display: block;
  margin-top: 6rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pill {
  flex-shrink: 0;
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #fff;
  background: #2f7d4f;
}

.member-pill {
  color: #687064;
  background: #f0f4e8;
}

/* 状态卡片 */
.state-card {
  margin-top: 48rpx;
  padding: 60rpx 28rpx;
  border: 1rpx dashed #dfe5d8;
  border-radius: 16rpx;
  text-align: center;
}

.state-text,
.error-text {
  display: block;
  color: #687064;
  font-size: 30rpx;
  line-height: 1.5;
}

.secondary-btn {
  margin-top: 32rpx;
  min-height: 80rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  color: #23613e;
  background: #fff;
  font: inherit;
  font-size: 28rpx;
  font-weight: 800;
}

/* 设置目标区域 */
.set-target-row {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.set-target-row .primary-btn {
  width: 100%;
  min-height: 88rpx;
  border: 0;
  border-radius: 16rpx;
  color: #fff;
  background: #2f7d4f;
  font: inherit;
  font-size: 30rpx;
  font-weight: 800;
  box-shadow: 0 16rpx 40rpx rgba(47, 125, 79, .2);
}

.set-target-row .ghost-btn {
  width: 100%;
  min-height: 80rpx;
  border: 1rpx solid rgba(47, 125, 79, .22);
  border-radius: 16rpx;
  color: #23613e;
  background: #fff;
  font: inherit;
  font-size: 28rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.target-set-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  background: #f0f4e8;
}

.hint-icon {
  color: #2f7d4f;
  font-size: 28rpx;
  font-weight: 900;
}

.hint-text {
  color: #4a6b3a;
  font-size: 26rpx;
  font-weight: 600;
}
