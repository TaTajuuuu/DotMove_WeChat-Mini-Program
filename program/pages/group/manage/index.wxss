/* 小组管理页面样式 */
.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  background: linear-gradient(180deg, rgba(47, 125, 79, 0.12), rgba(246, 247, 243, 0) 260px), #f6f7f3;
}

/* ========== 状态容器 ========== */
.state-container {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 60vh;
  padding-top: 120rpx;
}

.state-card {
  padding: 48rpx 36rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.94);
  text-align: center;
}

.state-text {
  font-size: 30rpx;
  color: #687064;
}

.error-text {
  font-size: 28rpx;
  color: #ba5148;
  line-height: 1.6;
}

.error-container {
  margin-top: 24rpx;
  padding: 0 8rpx;
}

/* ========== 自定义导航栏 ========== */
.nav-bar {
  display: grid;
  grid-template-columns: 68rpx 1fr 108rpx;
  align-items: center;
  height: 96rpx;
  padding: 0 8rpx;
}

.nav-back {
  width: 68rpx;
  height: 68rpx;
  display: grid;
  place-items: center;
  border: 1rpx solid rgba(32, 37, 31, 0.14);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.72);
}

.back-arrow {
  width: 18rpx;
  height: 18rpx;
  border-left: 3rpx solid #20251f;
  border-bottom: 3rpx solid #20251f;
  transform: rotate(45deg);
  margin-left: 6rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  color: #20251f;
  letter-spacing: 0;
}

.nav-capsule {
  justify-self: end;
  display: flex;
  width: 108rpx;
  height: 48rpx;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(32, 37, 31, 0.16);
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.76);
}

.capsule-more {
  display: flex;
  gap: 6rpx;
  align-items: center;
}

.more-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #20251f;
}

.capsule-circle {
  width: 24rpx;
  height: 24rpx;
  border: 3rpx solid #20251f;
  border-radius: 50%;
}

/* ========== 页面内容 ========== */
.page-content {
  padding-top: 8rpx;
}

/* ========== Hero 区域 ========== */
.hero {
  padding: 36rpx 0 28rpx;
}

.hero-title {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}

.hero-text {
  display: flex;
  flex-direction: column;
}

.hero-heading {
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.18;
  letter-spacing: 0;
  color: #20251f;
}

.hero-desc {
  margin-top: 16rpx;
  max-width: 400rpx;
  font-size: 28rpx;
  line-height: 1.55;
  color: #687064;
}

.hero-badge {
  flex: 0 0 auto;
  padding: 14rpx 20rpx;
  border-radius: 999px;
  border: 1rpx solid rgba(47, 125, 79, 0.2);
  color: #23613e;
  background: rgba(255, 255, 255, 0.72);
}

.badge-text {
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

/* ========== 通用卡片/面板 ========== */
.card,
.panel {
  margin-top: 24rpx;
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, 0.06);
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #20251f;
}

.section-meta {
  font-size: 24rpx;
  color: #8a9384;
}

/* ========== 小组名称 ========== */
.name-input-row {
  display: flex;
  align-items: center;
  min-height: 100rpx;
  padding: 0 26rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
}

.name-input {
  flex: 1;
  height: 100rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
}

.char-count {
  margin-left: auto;
  font-size: 24rpx;
  font-weight: 600;
  color: #8a9384;
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 24rpx;
  border: none;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #ffffff;
  background: #2f7d4f;
  display: grid;
  place-items: center;
}

.primary-btn::after {
  border: none;
}

.primary-btn[disabled] {
  opacity: 0.6;
}

/* ========== 邀请方式 ========== */
.invite-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 20rpx;
  align-items: center;
  margin-top: 20rpx;
  padding: 24rpx;
  border: 1rpx dashed rgba(47, 125, 79, 0.34);
  border-radius: 16rpx;
  background: #fbfcf8;
}

.invite-code {
  font-size: 44rpx;
  font-weight: 900;
  color: #23613e;
  letter-spacing: 4rpx;
}

.ghost-btn {
  min-height: 68rpx;
  padding: 0 32rpx;
  border: 1rpx solid rgba(47, 125, 79, 0.22);
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 800;
  color: #23613e;
  background: #ffffff;
  display: grid;
  place-items: center;
}

.ghost-btn::after {
  border: none;
}

/* ========== 成员管理 ========== */
.member-list {
  display: grid;
  gap: 20rpx;
}

.member-item {
  display: grid;
  grid-template-columns: 72rpx 1fr auto;
  gap: 20rpx;
  align-items: center;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #dfe5d8;
}

.member-item:last-child {
  padding-bottom: 0;
  border-bottom: 0;
}

.member-avatar {
  width: 72rpx;
  height: 72rpx;
  display: grid;
  place-items: center;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 900;
}

.avatar-creator {
  color: #5b420c;
  background: #f0b441;
}

.avatar-normal {
  color: #ffffff;
  background: #2f7d4f;
}

.avatar-mute {
  color: #687064;
  background: #dfe5d8;
}

.avatar-text {
  font-size: 26rpx;
  font-weight: 900;
}

.member-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.member-name {
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
  letter-spacing: 0;
  color: #20251f;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.35;
  color: #687064;
}

.member-right {
  flex: 0 0 auto;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999px;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 1.2;
}

.tag-creator {
  color: #5b420c;
  background: #fae6af;
}

.tag-member {
  color: #23613e;
  background: #eef5e8;
}

.member-actions {
  display: grid;
  gap: 12rpx;
}

.ghost-btn-small {
  min-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(47, 125, 79, 0.22);
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #23613e;
  background: #ffffff;
  display: grid;
  place-items: center;
}

.ghost-btn-small::after {
  border: none;
}

.danger-btn-small {
  min-height: 56rpx;
  padding: 0 20rpx;
  border: 1rpx solid rgba(186, 81, 72, 0.28);
  border-radius: 12rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
  background: #ba5148;
  display: grid;
  place-items: center;
}

.danger-btn-small::after {
  border: none;
}

/* ========== 危险操作 ========== */
.danger-panel {
  border-color: rgba(186, 81, 72, 0.2);
}

.danger-zone {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin-top: 4rpx;
}

.ghost-btn-wide {
  min-height: 88rpx;
  border: 1rpx solid rgba(47, 125, 79, 0.22);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #23613e;
  background: #ffffff;
  display: grid;
  place-items: center;
}

.ghost-btn-wide::after {
  border: none;
}

.danger-btn-wide {
  min-height: 88rpx;
  border: 1rpx solid rgba(186, 81, 72, 0.28);
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 800;
  color: #ffffff;
  background: #ba5148;
  display: grid;
  place-items: center;
}

.danger-btn-wide::after {
  border: none;
}

.danger-btn-wide[disabled] {
  opacity: 0.6;
}

.notice {
  display: flex;
  gap: 20rpx;
  align-items: flex-start;
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(240, 180, 65, 0.28);
  border-radius: 16rpx;
  color: #6c4a06;
  background: rgba(255, 246, 225, 0.9);
  font-size: 24rpx;
  line-height: 1.45;
}

.notice-icon {
  flex: 0 0 auto;
  width: 36rpx;
  height: 36rpx;
  display: grid;
  place-items: center;
  border-radius: 50%;
  background: #f0b441;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
}

.notice-text {
  font-size: 24rpx;
  line-height: 1.45;
  color: #6c4a06;
  white-space: pre-line;
}
