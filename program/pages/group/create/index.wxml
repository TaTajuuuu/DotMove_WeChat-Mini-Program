<view class="page">
  <!-- 导航栏 -->
  <view class="nav">
    <view class="back" bindtap="handleBack"></view>
    <text class="nav-title">创建小组</text>
    <view class="capsule">
      <view class="more-icon"><text></text></view>
      <view class="circle-icon"></view>
    </view>
  </view>

  <!-- Hero 区域 -->
  <view class="hero">
    <view class="hero-title">
      <view class="hero-text">
        <text class="hero-heading">发起一个\n月度运动约定</text>
        <text class="hero-desc">选择本月或下月，填写小组名称。</text>
      </view>
      <view class="month-badge">上限 50 人</view>
    </view>
  </view>

  <!-- 表单卡片 -->
  <view class="form-card">
    <!-- 周期选择 -->
    <view class="field-block">
      <view class="label-row">
        <text class="field-label">创建周期</text>
        <text class="helper"></text>
      </view>
      <view class="period-grid">
        <view class="period {{groupType === 'currentMonth' ? 'active' : ''}}" bindtap="handleTypeChange" data-type="currentMonth">
          <view class="topline">
            <text class="topline-name">本月小组</text>
            <view class="radio {{groupType === 'currentMonth' ? 'checked' : ''}}"></view>
          </view>
          <text class="period-date">{{currentMonthLabel}}</text>
          <text class="period-desc">{{currentMonthRange}}</text>
        </view>
        <view class="period {{groupType === 'nextMonth' ? 'active' : ''}}" bindtap="handleTypeChange" data-type="nextMonth">
          <view class="topline">
            <text class="topline-name">下月小组</text>
            <view class="radio {{groupType === 'nextMonth' ? 'checked' : ''}}"></view>
          </view>
          <text class="period-date">{{nextMonthLabel}}</text>
          <text class="period-desc">{{nextMonthRange}}</text>
        </view>
      </view>
    </view>

    <!-- 小组名称 -->
    <view class="field-block">
      <view class="label-row">
        <text class="field-label">小组名称</text>
        <text class="helper">1-20 个字符</text>
      </view>
      <view class="input-wrap">
        <input class="field-input" maxlength="20" placeholder="给小组起个名字" value="{{name}}" bindinput="handleNameInput" />
        <text class="input-count">{{name.length}}/20</text>
      </view>
    </view>

    <!-- 创建者昵称 -->
    <view class="field-block">
      <view class="label-row">
        <text class="field-label">我的昵称</text>
        <text class="helper">1-12 个字符</text>
      </view>
      <view class="input-wrap">
        <input class="field-input" maxlength="12" placeholder="其他成员看到的昵称" value="{{nickname}}" bindinput="handleNicknameInput" />
        <text class="input-count">{{nickname.length}}/12</text>
      </view>
    </view>

    <!-- 提示 -->
    <view wx:if="{{groupType === 'nextMonth'}}" class="notice">
      <text>下月小组开始前不可打卡，成员可设置昵称和目标。</text>
    </view>

    <!-- 错误提示 -->
    <view wx:if="{{errorMessage}}" class="notice danger">
      <text>{{errorMessage}}</text>
    </view>
  </view>

  <!-- 创建按钮 -->
  <button wx:if="{{!createdGroup}}" class="primary-btn" loading="{{submitting}}" disabled="{{submitting}}" bindtap="handleCreate">创建并生成邀请</button>

  <!-- 创建成功 -->
  <view wx:if="{{createdGroup}}" class="success-card">
    <view class="success-head">
      <view>
        <text class="success-title">创建成功</text>
        <text class="success-helper">下一步：设置小组运动目标，或先邀请成员。</text>
      </view>
      <view class="tag {{createdGroup.status === 'active' ? 'active' : ''}}">{{createdGroup.status === 'active' ? '进行中' : '未开始'}}</view>
    </view>
    <view class="invite-code">{{createdGroup.inviteCode}}</view>
    <view class="invite-actions">
      <button class="invite-action-btn" open-type="share">微信群分享</button>
      <button class="invite-action-btn" bindtap="handleCopyCode">复制邀请码</button>
    </view>
    <button class="target-action-btn" bindtap="handleSetTarget">去设置目标</button>
  </view>

  <view wx:if="{{showClipboardPrivacyDialog}}" class="privacy-mask">
    <view class="privacy-dialog">
      <text class="privacy-title">隐私保护提示</text>
      <text class="privacy-copy">复制邀请码需要使用剪切板。请阅读并同意《用户隐私保护指引》后继续。</text>
      <text class="privacy-contract-link" bindtap="handleOpenPrivacyContract">查看《用户隐私保护指引》</text>
      <view class="privacy-actions">
        <button class="privacy-cancel-btn" bindtap="handleCancelClipboardPrivacy">暂不使用</button>
        <button
          id="agree-btn"
          class="privacy-agree-btn"
          open-type="agreePrivacyAuthorization"
          bindtap="handleAgreeClipboardPrivacy"
          bindagreeprivacyauthorization="handleAgreeClipboardPrivacy"
        >同意并复制</button>
      </view>
    </view>
  </view>

  <!-- 自定义底部导航 -->
  <custom-tab-bar />
</view>
