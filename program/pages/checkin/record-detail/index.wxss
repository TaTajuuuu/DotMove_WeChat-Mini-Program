.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .2), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .18), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
}

.nav {
  display: grid;
  grid-template-columns: 68rpx 1fr 144rpx;
  align-items: center;
  height: 96rpx;
}

.back {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, .78);
}

.back::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  color: #20251f;
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
}

.capsule-placeholder {
  width: 144rpx;
}

.hero {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
  padding: 36rpx 0 28rpx;
}

.hero-title,
.hero-subtitle {
  display: block;
  color: #20251f;
  font-size: 56rpx;
  font-weight: 900;
  line-height: 1.12;
  letter-spacing: 0;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  color: #687064;
  font-size: 26rpx;
}

.badge,
.tag {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 8rpx;
  color: #23613e;
  background: rgba(255, 255, 255, .78);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.card,
.panel,
.state-card {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .94);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}

.panel {
  margin-top: 24rpx;
}

.section-head,
.field,
.metric {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  color: #20251f;
  font-size: 34rpx;
  font-weight: 800;
}

.section-meta {
  color: #8a9384;
  font-size: 24rpx;
}

.field,
.metric {
  min-height: 72rpx;
  border-bottom: 1rpx solid #eef0ea;
}

.field:last-child,
.metric:last-child {
  border-bottom: 0;
}

.field-label,
.metric-label {
  color: #20251f;
  font-size: 28rpx;
  font-weight: 700;
}

.field-value,
.metric-value {
  color: #23613e;
  font-size: 28rpx;
  font-weight: 900;
  text-align: right;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 14rpx;
}

.photo-item {
  aspect-ratio: 1;
  overflow: hidden;
  border: 1rpx solid #dfe5d8;
  border-radius: 12rpx;
  background: #eef2ea;
}

.photo-item image,
.photo-failed {
  width: 100%;
  height: 100%;
}

.photo-failed {
  display: grid;
  place-items: center;
  padding: 12rpx;
  box-sizing: border-box;
  color: #8a9384;
  font-size: 22rpx;
  text-align: center;
}

.remark {
  display: block;
  min-height: 80rpx;
  color: #4f584b;
  font-size: 27rpx;
  line-height: 1.6;
  overflow-wrap: anywhere;
}

.empty-hint,
.state-card {
  color: #8a9384;
  font-size: 26rpx;
  text-align: center;
}

.error-text {
  display: block;
  margin-bottom: 20rpx;
  color: #b84444;
}

.secondary-btn {
  width: 240rpx;
  height: 76rpx;
  color: #23613e;
  background: #fff;
  border: 1rpx solid #cfe0d3;
  font-size: 28rpx;
}

.edit-entry-btn {
  width: 100%;
  min-height: 78rpx;
  margin-top: 22rpx;
  border: 1rpx solid rgba(47, 125, 79, .25);
  border-radius: 12rpx;
  color: #23613e;
  background: #fff;
  font-size: 28rpx;
  font-weight: 800;
}

.edit-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  min-height: 92rpx;
  border-bottom: 1rpx solid #eef0ea;
}

.edit-label {
  display: block;
  color: #20251f;
  font-size: 28rpx;
  font-weight: 700;
}

.edit-hint {
  display: block;
  margin-top: 6rpx;
  color: #8a9384;
  font-size: 22rpx;
}

.edit-input-wrap {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.edit-input {
  width: 180rpx;
  height: 68rpx;
  padding: 0 16rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 10rpx;
  box-sizing: border-box;
  color: #23613e;
  background: #fbfcf8;
  font-size: 28rpx;
  font-weight: 800;
  text-align: right;
}

.edit-unit {
  width: 70rpx;
  color: #687064;
  font-size: 23rpx;
}

.switch {
  position: relative;
  width: 92rpx;
  height: 52rpx;
  border-radius: 26rpx;
  background: #2f7d4f;
}

.switch::after {
  content: "";
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
}

.switch.off {
  background: #dfe5d8;
}

.switch.off::after {
  right: 46rpx;
}

.edit-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 28rpx 0 16rpx;
}

.privacy-link {
  color: #23613e;
  font-size: 23rpx;
  font-weight: 700;
}

.edit-photo-item {
  position: relative;
}

.remove-photo {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  display: grid;
  place-items: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  color: #fff;
  background: rgba(32, 37, 31, .76);
  font-size: 32rpx;
  line-height: 1;
}

.add-photo {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #687064;
  font-size: 22rpx;
}

.add-photo-icon {
  color: #23613e;
  font-size: 42rpx;
  line-height: 1;
}

.remark-head {
  margin-bottom: 14rpx;
}

.edit-remark {
  width: 100%;
  min-height: 150rpx;
  padding: 20rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 12rpx;
  box-sizing: border-box;
  color: #20251f;
  background: #fbfcf8;
  font-size: 26rpx;
  line-height: 1.5;
}

.edit-error {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 10rpx;
  color: #b84444;
  background: #fff0f0;
  font-size: 24rpx;
}

.edit-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.cancel-edit-btn,
.save-edit-btn {
  min-height: 80rpx;
  margin: 0;
  border-radius: 12rpx;
  font-size: 27rpx;
  font-weight: 800;
}

.cancel-edit-btn {
  color: #687064;
  background: #f0f2ed;
}

.save-edit-btn {
  color: #fff;
  background: #2f7d4f;
}
