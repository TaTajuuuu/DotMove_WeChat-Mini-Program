.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 导航栏 */
.nav {
  display: grid;
  grid-template-columns: 68rpx 1fr 144rpx;
  align-items: center;
  height: 96rpx;
  padding: 0 0 0 8rpx;
}

.back {
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, .72);
  position: relative;
}

.back::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  text-align: center;
  letter-spacing: 0;
}

.capsule {
  justify-self: end;
  display: flex;
  width: 144rpx;
  height: 64rpx;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(32, 37, 31, .16);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, .76);
}

.circle-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #20251f;
  border-radius: 50%;
}

.more-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}

.more-icon::before,
.more-icon::after,
.more-icon span {
  content: "";
  position: absolute;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #20251f;
}

.more-icon::before { left: 2rpx; }
.more-icon span { left: 14rpx; }
.more-icon::after { left: 26rpx; }

/* Hero */
.hero {
  padding: 28rpx 0 24rpx;
}

.hero-title {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.hero-heading {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: 0;
  white-space: pre-line;
}

.hero-desc {
  margin-top: 16rpx;
  display: block;
  color: #687064;
  font-size: 28rpx;
  line-height: 1.55;
}

.badge {
  flex: 0 0 auto;
  padding: 14rpx 20rpx;
  border: 1rpx solid rgba(47, 125, 79, .2);
  border-radius: 999rpx;
  color: #23613e;
  background: rgba(255, 255, 255, .72);
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

/* 卡片 */
.card,
.panel {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}

.panel {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
}

.section-meta {
  color: #8a9384;
  font-size: 24rpx;
}

.tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.tag.soft { color: #5b420c; background: #fae6af; }

/* 日期选择网格 */
.date-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.date-card {
  padding: 28rpx 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
}

.date-card.selected {
  color: #fff;
  border-color: #2f7d4f;
  background: #2f7d4f;
}

.date-value {
  display: block;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1.25;
}

.date-name {
  display: block;
  margin-top: 10rpx;
  opacity: .74;
  font-size: 24rpx;
  line-height: 1.35;
}

/* 字段列表 */
.field-list {
  display: grid;
  gap: 24rpx;
}

.field-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.field-label {
  font-size: 30rpx;
  font-weight: 800;
  color: #20251f;
}

.field-input-inline {
  width: 160rpx;
  text-align: right;
  font-size: 32rpx;
  font-weight: 900;
  color: #23613e;
}

.field-unit {
  font-size: 26rpx;
  color: #687064;
  margin-left: 4rpx;
}

.field-desc {
  display: block;
  margin-top: 12rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.45;
}

/* 开关 */
.toggle-row {
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 16rpx;
  align-items: center;
  padding: 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
}

.toggle-title {
  font-size: 30rpx;
  font-weight: 800;
  color: #20251f;
}

.toggle-desc {
  display: block;
  margin-top: 8rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.4;
}

.switch {
  width: 92rpx;
  height: 52rpx;
  border-radius: 52rpx;
  background: #2f7d4f;
  position: relative;
}

.switch.off {
  background: #dfe5d8;
}

.switch::after {
  content: "";
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #fff;
}

.switch.off::after {
  right: auto;
  left: 6rpx;
}

/* 照片网格 */
.photo-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.photo-slot {
  min-height: 160rpx;
  padding: 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
  display: grid;
  place-items: center;
  color: #8a9384;
  font-size: 26rpx;
  font-weight: 800;
  text-align: center;
}

.photo-slot.filled {
  color: #fff;
  background: linear-gradient(135deg, #2f7d4f, #f0b441);
  border-color: transparent;
}

.remark-area {
  /* 备注区域 */
}

.remark-input {
  min-height: 88rpx;
  padding: 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
  font-size: 28rpx;
  line-height: 1.5;
}

/* 提示 */
.notice {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(240, 180, 65, .28);
  border-radius: 16rpx;
  color: #6c4a06;
  background: rgba(255, 246, 225, .9);
  font-size: 26rpx;
  line-height: 1.45;
}

/* 按钮 */
.primary-btn {
  width: 100%;
  min-height: 96rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  color: #fff;
  background: #2f7d4f;
  font: inherit;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 20rpx 48rpx rgba(47, 125, 79, .22);
}

.primary-btn[disabled] {
  opacity: .55;
}
