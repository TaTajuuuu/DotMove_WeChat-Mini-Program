.state-card,
.field-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .94);
}

.field-label,
.hint,
.error-text {
  display: block;
}

.field-label {
  color: #20251f;
  font-size: 28rpx;
  font-weight: 800;
}

.field-label.sub {
  margin-top: 18rpx;
}

.picker-value,
.number-input,
.remark-input {
  margin-top: 12rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: #fff;
  font-size: 28rpx;
}

.picker-value,
.number-input {
  height: 76rpx;
  line-height: 76rpx;
}

.remark-input {
  width: 100%;
  height: 160rpx;
  padding-top: 18rpx;
}

.checkbox-label {
  display: block;
  margin-top: 18rpx;
  color: #20251f;
  font-size: 26rpx;
}

.secondary-btn,
.primary-btn {
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.secondary-btn {
  width: 100%;
  color: #23613e;
  background: #f0f4e8;
}

.primary-btn {
  width: 100%;
  margin-top: 28rpx;
  color: #fff;
  background: #2f7d4f;
}

.hint {
  margin-top: 12rpx;
  color: #687064;
  font-size: 24rpx;
}

.error-text {
  margin-top: 18rpx;
  color: #ba5148;
  font-size: 26rpx;
}

.photo-preview-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-preview-item {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  overflow: hidden;
}

.photo-preview-img {
  width: 100%;
  height: 100%;
}

.photo-preview-remove {
  position: absolute;
  top: 0;
  right: 0;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 28rpx;
  line-height: 40rpx;
  text-align: center;
  border-radius: 0 0 0 8rpx;
}
