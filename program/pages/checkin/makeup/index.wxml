<view class="page">
  <!-- 导航栏 -->
  <view class="nav">
    <view class="back" bindtap="handleBack"></view>
    <text class="nav-title">补卡</text>
    <view class="capsule">
      <view class="more-icon"><text></text></view>
      <view class="circle-icon"></view>
    </view>
  </view>

  <!-- Hero 区域 -->
  <view class="hero">
    <view class="hero-title">
      <view class="hero-text">
        <text class="hero-heading">补交记录\n补昨日或前天</text>
        <text class="hero-desc">仅可补交最近两天的运动记录。</text>
      </view>
      <view class="badge">{{groupName || '未选择小组'}}</view>
    </view>
  </view>

  <!-- 补卡日期选择 -->
  <view class="card">
    <view class="section-head">
      <text class="section-title">补卡日期</text>
      <text class="section-meta">今日还可补 {{remainingDailyMakeupCount}} 次</text>
    </view>
    <view class="date-grid">
      <view class="date-card {{selectedDate === yesterdayKey ? 'selected' : ''}}" bindtap="handleDateSelect" data-date="{{yesterdayKey}}">
        <text class="date-value">{{yesterdayLabel}}</text>
        <text class="date-name">昨日</text>
      </view>
      <view class="date-card {{selectedDate === dayBeforeKey ? 'selected' : ''}}" bindtap="handleDateSelect" data-date="{{dayBeforeKey}}">
        <text class="date-value">{{dayBeforeLabel}}</text>
        <text class="date-name">前天</text>
      </view>
    </view>
    <view class="notice limit-notice">
      <text>所选日期还可提交 {{remainingSportDateCount}} 条有效记录；打卡和补卡合计上限为 5 条。</text>
    </view>
  </view>

  <!-- 运动数据 -->
  <view class="panel">
    <view class="section-head">
      <text class="section-title">运动数据</text>
      <text class="tag soft">补卡</text>
    </view>
    <view class="field-list">
      <view class="field" wx:for="{{goalFields}}" wx:key="key">
        <view class="field-row">
          <text class="field-label">{{item.label}}</text>
          <input class="field-input-inline" type="digit" placeholder="--" value="{{fieldValues[item.key]}}" data-key="{{item.key}}" bindinput="handleFieldInput" />
          <text class="field-unit">{{item.unit}}</text>
        </view>
        <text class="field-desc">{{item.desc}}</text>
      </view>
    </view>
  </view>

  <!-- 三环闭合 -->
  <view class="panel" wx:if="{{showRings}}">
    <view class="toggle-row">
      <view class="toggle-info">
        <text class="toggle-title">三环闭合</text>
        <text class="toggle-desc">该运动日是否成功闭合三环</text>
      </view>
      <view class="switch {{ringsClosed ? '' : 'off'}}" bindtap="handleToggleRings"></view>
    </view>
  </view>

  <!-- 照片和备注 -->
  <view class="panel">
    <view class="section-head">
      <text class="section-title">照片和备注</text>
      <text class="section-meta privacy-link" bindtap="handleOpenPrivacyContract">隐私指引 · {{photos.length}}/3</text>
    </view>
    <view class="photo-grid">
      <block wx:for="{{photos}}" wx:key="*this">
        <view class="photo-slot filled" data-index="{{index}}" bindtap="handlePreviewPhoto">
          <text>已上传</text>
        </view>
      </block>
      <block wx:if="{{photos.length < 3}}">
        <view class="photo-slot" bindtap="handleChoosePhoto">
          <text>添加照片</text>
        </view>
      </block>
    </view>
    <view class="remark-area">
      <input class="remark-input" maxlength="100" placeholder="选填，备注运动感受..." value="{{remark}}" bindinput="handleRemarkInput" />
    </view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{errorMessage}}" class="notice">
    <text>{{errorMessage}}</text>
  </view>

  <!-- 提交按钮 -->
  <button
    class="primary-btn"
    loading="{{submitting}}"
    disabled="{{submitting || remainingDailyMakeupCount <= 0 || remainingSportDateCount <= 0}}"
    bindtap="handleSubmit"
  >提交补卡</button>
  <view wx:if="{{showPrivacyDialog}}" class="privacy-mask">
    <view class="privacy-dialog">
      <text class="privacy-title">运动照片隐私说明</text>
      <text class="privacy-copy">你选择的运动照片将上传至微信云存储。内容安全审核通过后，同组有效成员可以在打卡详情中查看，用于相互监督。</text>
      <text class="privacy-contract-link" bindtap="handleOpenPrivacyContract">查看《用户隐私保护指引》</text>
      <view class="privacy-actions">
        <button class="privacy-cancel-btn" bindtap="handleCancelPrivacyAuthorization">暂不使用</button>
        <button
          id="agree-btn"
          class="privacy-agree-btn"
          open-type="agreePrivacyAuthorization"
          bindtap="handleAgreePrivacyAuthorization"
          bindagreeprivacyauthorization="handleAgreePrivacyAuthorization"
        >同意并继续</button>
      </view>
    </view>
  </view>

  <custom-tab-bar />
</view>
