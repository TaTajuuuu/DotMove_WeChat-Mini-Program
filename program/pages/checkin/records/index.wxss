.state-card,
.record-card {
  margin-top: 22rpx;
  padding: 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .94);
}

.record-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.record-date,
.record-meta,
.record-remark,
.error-text {
  display: block;
}

.record-date {
  color: #20251f;
  font-size: 30rpx;
  font-weight: 800;
}

.tag {
  flex-shrink: 0;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  color: #23613e;
  background: #f0f4e8;
  font-size: 24rpx;
}

.record-meta,
.record-remark {
  margin-top: 10rpx;
  color: #687064;
  font-size: 24rpx;
}

.error-text {
  color: #ba5148;
  font-size: 26rpx;
}
