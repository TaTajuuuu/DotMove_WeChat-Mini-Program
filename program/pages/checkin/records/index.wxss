.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 导航栏 */
.nav {
  display: grid;
  grid-template-columns: 68rpx 1fr 144rpx;
  align-items: center;
  height: 96rpx;
}

.back {
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 34rpx;
  background: rgba(255, 255, 255, .72);
  position: relative;
}
.back::before {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 36rpx;
  text-align: center;
  color: #20251f;
  font-weight: 800;
}

.capsule {
  justify-self: end;
  display: flex;
  align-items: center;
  justify-content: space-around;
  width: 144rpx;
  height: 64rpx;
  border: 1rpx solid rgba(32, 37, 31, .16);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, .76);
}
.more-icon,
.circle-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}
.circle-icon {
  border: 4rpx solid #20251f;
  border-radius: 50%;
}
.more-icon::before,
.more-icon::after,
.more-icon text {
  content: "";
  position: absolute;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #20251f;
}
.more-icon::before { left: 2rpx; }
.more-icon::after { left: 14rpx; }

/* Hero */
.hero {
  padding: 36rpx 0 28rpx;
}
.hero-title {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: flex-start;
}
.hero-heading {
  display: block;
  font-size: 56rpx;
  line-height: 1.18;
  letter-spacing: 0;
  font-weight: 900;
  color: #20251f;
}
.hero-desc {
  margin-top: 16rpx;
  display: block;
  color: #687064;
  font-size: 26rpx;
  line-height: 1.55;
}
.badge {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border: 1rpx solid rgba(47, 125, 79, .2);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
  color: #23613e;
  background: rgba(255, 255, 255, .72);
}

/* 卡片 */
.card,
.panel {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}
.panel {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
  margin-bottom: 20rpx;
}
.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #20251f;
}
.section-meta {
  color: #8a9384;
  font-size: 24rpx;
}

.tag {
  padding: 10rpx 18rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}
.tag.good {
  color: #fff;
  background: #2f7d4f;
}

.field-list {
  display: grid;
  gap: 20rpx;
}
.field {
  padding: 12rpx 0;
}
.field-row {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  align-items: center;
}
.field-label {
  font-size: 28rpx;
  font-weight: 700;
  color: #20251f;
}
.field-value {
  font-size: 32rpx;
  font-weight: 900;
  color: #23613e;
  white-space: nowrap;
}
.field-desc {
  margin-top: 12rpx;
  display: block;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.4;
}

/* 日期筛选 */
.date-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}
.date-card {
  padding: 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
}
.date-card.selected {
  color: #fff;
  border-color: #2f7d4f;
  background: #2f7d4f;
}
.date-name {
  display: block;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.25;
}
.date-sub {
  display: block;
  margin-top: 12rpx;
  opacity: .74;
  font-size: 22rpx;
  line-height: 1.35;
}

/* 记录项 */
.record-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid #eef0ea;
}
.record-item:active {
  opacity: .68;
}
.record-item:last-child {
  border-bottom: none;
}
.record-date {
  font-size: 28rpx;
  font-weight: 800;
  color: #20251f;
}
.record-calories {
  font-size: 32rpx;
  font-weight: 900;
  color: #23613e;
  white-space: nowrap;
}
.record-value-row {
  display: flex;
  gap: 14rpx;
  align-items: center;
}
.record-chevron {
  color: #23613e;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}
.record-detail {
  margin-top: 10rpx;
  display: block;
  color: #687064;
  font-size: 24rpx;
}

.record-review-status {
  display: block;
  margin-top: 8rpx;
  color: #9a6410;
  font-size: 24rpx;
  font-weight: 700;
}

/* 加载 & 空 */
.loading-card {
  text-align: center;
  padding: 60rpx 0;
}
.loading-text,
.empty-hint {
  color: #8a9384;
  font-size: 28rpx;
}
.empty-hint {
  text-align: center;
  padding: 40rpx 0;
}

/* 错误 */
.notice {
  margin-top: 24rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(240, 180, 65, .28);
  border-radius: 16rpx;
  color: #6c4a06;
  background: rgba(255, 246, 225, .9);
  font-size: 24rpx;
  line-height: 1.45;
}
.error-notice {
  color: #742a2a;
  background: rgba(255, 235, 235, .9);
  border-color: rgba(200, 80, 80, .28);
}

/* 进度条 */
.progress-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #eef0ea;
}
.progress-item {
  margin-bottom: 20rpx;
}
.progress-item:last-child {
  margin-bottom: 0;
}
.progress-label {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 10rpx;
  font-size: 24rpx;
  color: #687064;
}
.progress-label text:last-child {
  font-weight: 700;
  color: #20251f;
}
.progress-bar {
  height: 12rpx;
  border-radius: 6rpx;
  background: #e8ece4;
  overflow: hidden;
}
.progress-fill {
  height: 100%;
  border-radius: 6rpx;
  background: #2f7d4f;
  transition: width .4s ease;
}
.progress-item .progress-fill[style*="100%"] {
  background: #23613e;
}

/* tag 变体 */
.tag.warn {
  color: #6c4a06;
  background: rgba(240, 180, 65, .28);
}
