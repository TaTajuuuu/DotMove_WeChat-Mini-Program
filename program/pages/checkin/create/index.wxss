.page {
  min-height: 100vh;
  padding: 0 18px 200rpx;
  background: radial-gradient(circle at 18% 6%, rgba(240,180,65,.22), transparent 150px), linear-gradient(180deg, rgba(47,125,79,.2), rgba(246,247,243,0) 260px), #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 导航 */
.nav { display: grid; grid-template-columns: 68rpx 1fr 144rpx; align-items: center; height: 96rpx; padding: 0 0 0 8rpx; }
.back { width: 68rpx; height: 68rpx; border: 1rpx solid rgba(32,37,31,.14); border-radius: 34rpx; background: rgba(255,255,255,.72); position: relative; }
.back::before { content: ""; position: absolute; left: 26rpx; top: 20rpx; width: 18rpx; height: 18rpx; border-left: 4rpx solid #20251f; border-bottom: 4rpx solid #20251f; transform: rotate(45deg); }
.nav-title { font-size: 36rpx; font-weight: 800; text-align: center; }
.capsule { justify-self: end; display: flex; width: 144rpx; height: 64rpx; align-items: center; justify-content: space-around; border: 1rpx solid rgba(32,37,31,.16); border-radius: 36rpx; background: rgba(255,255,255,.76); }
.circle-icon { width: 36rpx; height: 36rpx; border: 4rpx solid #20251f; border-radius: 50%; }
.more-icon { position: relative; width: 36rpx; height: 36rpx; }
.more-icon::before, .more-icon::after, .more-icon text { content: ""; position: absolute; top: 16rpx; width: 8rpx; height: 8rpx; border-radius: 50%; background: #20251f; }
.more-icon::before { left: 2rpx; }
.more-icon text { left: 14rpx; }
.more-icon::after { left: 26rpx; }

/* Hero */
.hero { padding: 28rpx 0 24rpx; }
.hero.compact { padding: 16rpx 0 20rpx; }
.hero-heading { font-size: 56rpx; font-weight: 800; line-height: 1.18; white-space: pre-line; }
.hero.compact .hero-heading { font-size: 44rpx; }
.hero-desc { display: block; margin-top: 16rpx; color: #687064; font-size: 28rpx; line-height: 1.55; }
.hero-row { display: flex; justify-content: space-between; gap: 16rpx; align-items: flex-start; }

/* Badge */
.badge { flex-shrink: 0; padding: 14rpx 20rpx; border: 1rpx solid rgba(47,125,79,.2); border-radius: 999rpx; color: #23613e; background: rgba(255,255,255,.72); font-size: 24rpx; font-weight: 800; display: flex; align-items: center; gap: 6rpx; }
.badge-alt { font-size: 22rpx; opacity: .7; }

/* 卡片 */
.card, .panel { padding: 28rpx; border: 1rpx solid #dfe5d8; border-radius: 16rpx; background: rgba(255,255,255,.92); box-shadow: 0 16rpx 40rpx rgba(38,54,34,.06); }
.panel { margin-top: 24rpx; }
.section-head { display: flex; justify-content: space-between; gap: 16rpx; align-items: center; margin-bottom: 24rpx; }
.section-title { font-size: 32rpx; font-weight: 800; color: #20251f; }
.section-meta { color: #8a9384; font-size: 24rpx; }
.tag { padding: 10rpx 20rpx; border-radius: 999rpx; font-size: 24rpx; font-weight: 800; }
.tag.good { color: #fff; background: #2f7d4f; }

/* 字段 */
.field-list { display: grid; gap: 24rpx; }
.field-item { }
.field-row { display: flex; justify-content: space-between; gap: 16rpx; align-items: center; }
.field-label { font-size: 30rpx; font-weight: 800; color: #20251f; }
.field-val { font-size: 34rpx; font-weight: 900; color: #23613e; }
.field-input { width: 160rpx; text-align: right; font-size: 32rpx; font-weight: 900; color: #23613e; }
.field-unit { font-size: 26rpx; color: #687064; margin-left: 4rpx; }
.field-desc { display: block; margin-top: 12rpx; color: #687064; font-size: 24rpx; line-height: 1.45; }
.field-meta { color: #8a9384; font-size: 24rpx; }

/* 开关 */
.toggle-row { display: grid; grid-template-columns: 1fr auto; gap: 16rpx; align-items: center; padding: 24rpx; border: 1rpx solid #dfe5d8; border-radius: 16rpx; background: #fbfcf8; }
.toggle-title { font-size: 30rpx; font-weight: 800; color: #20251f; }
.toggle-desc { display: block; margin-top: 8rpx; color: #687064; font-size: 24rpx; }
.switch { width: 92rpx; height: 52rpx; border-radius: 52rpx; background: #2f7d4f; position: relative; }
.switch.off { background: #dfe5d8; }
.switch::after { content: ""; position: absolute; top: 6rpx; right: 6rpx; width: 40rpx; height: 40rpx; border-radius: 50%; background: #fff; }
.switch.off::after { right: auto; left: 6rpx; }

/* 照片 */
.photo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16rpx; }
.photo-slot { min-height: 160rpx; padding: 24rpx; border: 1rpx solid #dfe5d8; border-radius: 16rpx; background: #fbfcf8; display: grid; place-items: center; color: #8a9384; font-size: 26rpx; font-weight: 800; }
.photo-slot.filled { color: #fff; background: linear-gradient(135deg, #2f7d4f, #f0b441); border-color: transparent; }

/* 备注 */
.remark-input { min-height: 88rpx; margin-top: 16rpx; padding: 22rpx; border: 1rpx solid #dfe5d8; border-radius: 16rpx; background: #fbfcf8; font-size: 28rpx; }

/* 提示 */
.notice { margin-top: 24rpx; padding: 24rpx; border: 1rpx solid rgba(240,180,65,.28); border-radius: 16rpx; color: #6c4a06; background: rgba(255,246,225,.9); font-size: 26rpx; }

/* 按钮 */
.primary-btn { width: 100%; min-height: 96rpx; margin-top: 28rpx; border: 0; border-radius: 16rpx; color: #fff; background: #2f7d4f; font-size: 32rpx; font-weight: 800; box-shadow: 0 20rpx 48rpx rgba(47,125,79,.22); }
.primary-btn[disabled] { opacity: .55; }
.primary-btn.small { width: auto; min-height: 76rpx; padding: 0 48rpx; margin-top: 0; display: inline-block; font-size: 28rpx; }
.secondary-link { display: block; margin-top: 24rpx; color: #23613e; font-size: 28rpx; font-weight: 800; text-align: center; }
.secondary-line-btn { width: auto; min-height: 76rpx; padding: 0 48rpx; margin-top: 16rpx; border: 1rpx solid #dfe5d8; border-radius: 16rpx; background: transparent; color: #23613e; font-size: 28rpx; font-weight: 800; }

/* ===== 小组选择列表 ===== */
.group-list { display: grid; gap: 24rpx; margin-top: 16rpx; }
.group-card { padding: 28rpx; border: 1rpx solid #dfe5d8; border-radius: 16rpx; background: rgba(255,255,255,.92); box-shadow: 0 8rpx 28rpx rgba(38,54,34,.04); }
.group-card.active { border-color: #2f7d4f; box-shadow: 0 8rpx 32rpx rgba(47,125,79,.14); background: linear-gradient(135deg, rgba(47,125,79,.03), rgba(240,180,65,.05)); }
.group-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 18rpx; }
.group-card-name { font-size: 34rpx; font-weight: 800; color: #20251f; }
.group-card-tag { padding: 6rpx 16rpx; border-radius: 999rpx; font-size: 22rpx; font-weight: 800; }
.group-card-tag.active { color: #fff; background: #2f7d4f; }
.group-card-tag.upcoming { color: #5b420c; background: #fae6af; }
.group-card-row { display: flex; align-items: center; gap: 12rpx; margin-bottom: 16rpx; }
.mini-bar { flex: 1; height: 10rpx; border-radius: 5rpx; background: #e9ece5; overflow: hidden; }
.mini-fill { height: 100%; border-radius: 5rpx; background: linear-gradient(90deg, #2f7d4f, #f0b441); }
.group-card-num { font-size: 24rpx; color: #8a9384; font-weight: 600; }
.group-card-hint { font-size: 24rpx; color: #8a9384; }

/* 空状态 */
.empty-state { margin-top: 80rpx; text-align: center; }
.empty-text { display: block; font-size: 30rpx; color: #687064; margin-bottom: 36rpx; }

/* 状态卡片 */
.state-card { margin-top: 60rpx; padding: 48rpx; text-align: center; color: #8a9384; font-size: 28rpx; background: rgba(255,255,255,.72); border-radius: 16rpx; }
