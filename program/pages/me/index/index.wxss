.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* 导航栏 */
.nav {
  display: grid;
  grid-template-columns: 1fr 144rpx;
  align-items: center;
  height: 96rpx;
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.capsule {
  justify-self: end;
  display: flex;
  width: 144rpx;
  height: 64rpx;
  align-items: center;
  justify-content: space-around;
  border: 1rpx solid rgba(32, 37, 31, .16);
  border-radius: 36rpx;
  background: rgba(255, 255, 255, .76);
}

.circle-icon {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #20251f;
  border-radius: 50%;
}

.more-icon {
  position: relative;
  width: 36rpx;
  height: 36rpx;
}

.more-icon::before,
.more-icon::after,
.more-icon span {
  content: "";
  position: absolute;
  top: 16rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #20251f;
}

.more-icon::before { left: 2rpx; }
.more-icon span { left: 14rpx; }
.more-icon::after { left: 26rpx; }

/* Hero */
.hero {
  padding: 28rpx 0 24rpx;
}

.hero-title {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.hero-heading {
  font-size: 56rpx;
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: 0;
  white-space: pre-line;
}

.hero-desc {
  margin-top: 16rpx;
  display: block;
  color: #687064;
  font-size: 28rpx;
  line-height: 1.55;
}

.badge {
  flex: 0 0 auto;
  padding: 14rpx 20rpx;
  border: 1rpx solid rgba(47, 125, 79, .2);
  border-radius: 999rpx;
  color: #23613e;
  background: rgba(255, 255, 255, .72);
  font-size: 24rpx;
  font-weight: 800;
}

/* 卡片 */
.card,
.panel {
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40rpx rgba(38, 54, 34, .06);
}

.panel {
  margin-top: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #20251f;
}

.section-meta {
  color: #8a9384;
  font-size: 24rpx;
}

.tag {
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.tag.soft { color: #5b420c; background: #fae6af; }

/* 小组行 */
.field-list {
  display: grid;
  gap: 20rpx;
}

.group-row {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  gap: 16rpx;
  align-items: center;
  padding: 24rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: #fbfcf8;
}

.group-name {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #20251f;
}

.group-meta {
  display: block;
  margin-top: 10rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.35;
}

.chev {
  color: #23613e;
  font-size: 44rpx;
  font-weight: 900;
}

/* 字段 */
.field-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: center;
}

.field-label {
  font-size: 30rpx;
  font-weight: 800;
  color: #20251f;
}

.field-value {
  font-size: 34rpx;
  font-weight: 900;
  color: #23613e;
}

.field-desc {
  display: block;
  margin-top: 12rpx;
  color: #687064;
  font-size: 24rpx;
  line-height: 1.45;
}

/* 按钮 */
.primary-btn {
  width: 100%;
  min-height: 96rpx;
  margin-top: 28rpx;
  border: 0;
  border-radius: 16rpx;
  color: #fff;
  background: #2f7d4f;
  font: inherit;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 20rpx 48rpx rgba(47, 125, 79, .22);
}

/* 日历 */
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 12rpx;
}

.calendar-day {
  aspect-ratio: 1;
  display: grid;
  place-items: center;
  border-radius: 12rpx;
  color: #8a9384;
  background: #e5e9df;
  font-size: 24rpx;
  font-weight: 800;
}

.calendar-day.done {
  color: #fff;
  background: #2f7d4f;
}

.calendar-day.blank {
  opacity: .45;
}

/* 状态卡片 */
.state-card {
  margin-top: 48rpx;
  padding: 60rpx 28rpx;
  border: 1rpx dashed #dfe5d8;
  border-radius: 16rpx;
  text-align: center;
}

.state-text,
.error-text {
  display: block;
  color: #687064;
  font-size: 30rpx;
}
