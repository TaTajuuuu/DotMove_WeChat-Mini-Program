.page {
  min-height: 100vh;
  padding: 0 36rpx 200rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .22), transparent 300rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .2), rgba(246, 247, 243, 0) 520rpx),
    #f6f7f3;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ===== 导航栏 ===== */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 96rpx;
  padding-top: 8rpx;
}

.back-btn {
  width: 68rpx;
  height: 68rpx;
  border: 1rpx solid rgba(32, 37, 31, .14);
  border-radius: 50%;
  background: rgba(255, 255, 255, .72);
  position: relative;
}

.back-btn::after {
  content: "";
  position: absolute;
  left: 26rpx;
  top: 20rpx;
  width: 18rpx;
  height: 18rpx;
  border-left: 4rpx solid #20251f;
  border-bottom: 4rpx solid #20251f;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #20251f;
  text-align: center;
}

.capsule-placeholder {
  width: 144rpx;
  height: 64rpx;
}

/* ===== Hero ===== */
.hero {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
  padding: 28rpx 0 20rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-title {
  display: block;
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: 900;
  color: #20251f;
  letter-spacing: -1rpx;
}

.hero-subtitle {
  display: block;
  font-size: 56rpx;
  line-height: 1.18;
  font-weight: 300;
  color: #20251f;
  letter-spacing: -1rpx;
}

.hero-desc {
  display: block;
  margin-top: 16rpx;
  color: #687064;
  font-size: 26rpx;
  line-height: 1.55;
}

.badge {
  flex-shrink: 0;
  padding: 14rpx 20rpx;
  border: 1rpx solid rgba(47, 125, 79, .2);
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  color: #23613e;
  background: rgba(255, 255, 255, .72);
  white-space: nowrap;
}

/* ===== 卡片 ===== */
.card {
  margin-top: 16rpx;
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, .92);
  box-shadow: 0 16rpx 40px rgba(38, 54, 34, .06);
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #20251f;
}

.tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.2;
}

.tag.soft {
  color: #5b420c;
  background: #fae6af;
}

/* ===== 一点币 ===== */
.coin-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  min-height: 80rpx;
  padding: 10rpx 26rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 12rpx;
  background: #fbfcf8;
}

.coin-label {
  font-size: 28rpx;
  font-weight: 800;
  color: #20251f;
  flex-shrink: 0;
}

.coin-value {
  font-size: 32rpx;
  font-weight: 900;
  color: #23613e;
}

.coin-unit {
  font-size: 24rpx;
  font-weight: 600;
  color: #8a9384;
  flex-shrink: 0;
  margin-left: 8rpx;
}

/* ===== 统计摘要 ===== */
.summary-row {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 14rpx 0;
}

.summary-item {
  font-size: 24rpx;
  color: #687064;
}

.summary-num {
  color: #23613e;
  font-weight: 800;
}

/* ===== 指标卡片 ===== */
.metric-list {
  display: grid;
  gap: 16rpx;
}

.metric-card {
  padding: 22rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 12rpx;
  background: #fbfcf8;
}

.metric-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 12rpx;
}

.metric-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #20251f;
}

.metric-value {
  font-size: 28rpx;
  font-weight: 900;
  color: #23613e;
  white-space: nowrap;
}

/* ===== 进度条 ===== */
.progress-line {
  height: 16rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #dfe5d8;
  margin-top: 16rpx;
}

.progress-fill {
  display: block;
  height: 100%;
  border-radius: 999rpx;
  background: #2f7d4f;
  transition: width .3s ease;
}

.metric-hint {
  display: block;
  margin-top: 10rpx;
  color: #687064;
  font-size: 24rpx;
}

/* ===== 空提示 ===== */
.empty-hint {
  padding: 30rpx 20rpx;
  text-align: center;
  color: #8a9384;
  font-size: 26rpx;
}

/* ===== 按钮 ===== */
.primary-btn {
  width: 100%;
  height: 88rpx;
  margin-top: 28rpx;
  border: none;
  border-radius: 16rpx;
  color: #fff;
  background: #2f7d4f;
  font-size: 32rpx;
  font-weight: 800;
  box-shadow: 0 20rpx 48rpx rgba(47, 125, 79, .22);
}

/* ===== 状态/错误 ===== */
.state-card {
  margin-top: 60rpx;
  padding: 40rpx;
  text-align: center;
  color: #8a9384;
  font-size: 28rpx;
}

.error-text {
  color: #ba5148;
}
