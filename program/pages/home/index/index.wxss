.home-page {
  padding-bottom: 120rpx;
}

.hero {
  padding: 24rpx 0 12rpx;
}

.eyebrow {
  display: block;
  color: #23613e;
  font-size: 24rpx;
  font-weight: 800;
}

.action-panel,
.state-block,
.group-card,
.archive-row {
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .94);
}

.action-panel {
  margin-top: 28rpx;
  padding: 24rpx;
}

.join-row {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.invite-input {
  flex: 1;
  min-width: 0;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: #fff;
  font-size: 28rpx;
}

.primary-btn,
.secondary-btn {
  height: 80rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-btn {
  width: 100%;
  color: #fff;
  background: #2f7d4f;
}

.secondary-btn {
  width: 144rpx;
  color: #23613e;
  background: #f0f4e8;
}

.state-block {
  margin-top: 28rpx;
  padding: 32rpx 24rpx;
}

.state-title,
.state-desc {
  display: block;
  font-size: 28rpx;
  line-height: 1.5;
}

.state-title {
  font-weight: 800;
}

.state-desc {
  margin-top: 8rpx;
  color: #687064;
}

.section {
  margin-top: 32rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 800;
}

.group-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 16rpx;
  padding: 24rpx;
}

.group-name,
.group-meta {
  display: block;
}

.group-name {
  font-size: 32rpx;
  font-weight: 800;
}

.group-meta {
  margin-top: 8rpx;
  color: #687064;
  font-size: 24rpx;
}

.target-pill {
  flex-shrink: 0;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  color: #23613e;
  background: #f0f4e8;
  font-size: 24rpx;
}

.target-pill.muted {
  color: #687064;
  background: #f6f7f3;
}

.archive-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 14rpx;
  padding: 22rpx 24rpx;
  color: #20251f;
  font-size: 26rpx;
}
