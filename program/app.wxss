page {
  min-height: 100%;
  color: #20251f;
  background: #f6f7f3;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  font: inherit;
}

.page {
  min-height: 100vh;
  padding: 40rpx 32rpx 72rpx;
  background:
    radial-gradient(circle at 18% 6%, rgba(240, 180, 65, .18), transparent 220rpx),
    linear-gradient(180deg, rgba(47, 125, 79, .16), rgba(246, 247, 243, 0) 360rpx),
    #f6f7f3;
}

.page-title {
  display: block;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.18;
  letter-spacing: 0;
}

.page-desc {
  display: block;
  margin-top: 16rpx;
  color: #687064;
  font-size: 28rpx;
  line-height: 1.55;
}

.placeholder-card {
  margin-top: 32rpx;
  padding: 28rpx;
  border: 1rpx solid #dfe5d8;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, .92);
}

.placeholder-label {
  display: block;
  color: #23613e;
  font-size: 24rpx;
  font-weight: 800;
}

.placeholder-text {
  display: block;
  margin-top: 12rpx;
  color: #687064;
  font-size: 26rpx;
  line-height: 1.55;
}
