/* ============================================
   一点运动 - 全局样式（Design System）
   prototype 设计规范
   ============================================ */

/* CSS 变量定义 */
page {
  /* 配色方案（严格匹配原型） */
  --page: #f6f7f3;
  --surface: #ffffff;
  --surface-soft: #f0f4e8;
  --ink: #20251f;
  --muted: #687064;
  --quiet: #8a9384;
  --line: #dfe5d8;
  --brand: #2f7d4f;
  --brand-dark: #23613e;
  --accent: #f0b441;
  --danger: #ba5148;

  /* 基础样式 */
  min-height: 100%;
  color: var(--ink);
  background: var(--page);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Microsoft YaHei", sans-serif;
}

/* 重置 box-sizing */
view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  font: inherit;
  margin: 0;
  padding: 0;
  background: transparent;
  border: none;
  line-height: inherit;
}

button::after {
  border: none;
}
